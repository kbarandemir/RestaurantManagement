## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## See https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][In][33]2/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[L|l]og [F|f]iles/

# Visual Studio 2015/2017/2019/2022 cache build results
.vs/
# Unlock next line if you want to check-in [Visual Studio 2015 outcome directory]
# ASP.NET Core publish output
**/publish/

# MSBuild stacktrace
*.stackdump

# Core
**/bin/
**/obj/

# SQLite
*.db
*.db-journal
*.db-shm
*.db-wal

# Frontend
restaurant-frontend/dist
restaurant-frontend/node_modules
restaurant-frontend/.env.local
restaurant-frontend/.env.development.local
restaurant-frontend/.env.test.local
restaurant-frontend/.env.production.local

# OS files
.DS_Store
Thumbs.db
